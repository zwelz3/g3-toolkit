# === Build artifacts ===
# ROOT-ANCHORED deliberately. Any-depth `dist/` and `coverage/` rules
# silently swallowed SOURCE (tests/dist/public-api.test.ts, which is
# how verify:exports lost its tests; packages/react/src/views/coverage/,
# which broke CI typecheck on first push; scripts/storybook-static/).
# If a new artifact dir appears somewhere deeper, add its explicit
# path; never a bare directory name.
/dist/
/build/
docs/build/
packages/*/dist
packages/*/tsconfig.tsbuildinfo

# === Sphinx copies (from build_docs.py) ===
docs/source/specs/
docs/source/research/
docs/source/planning/

# === Dependencies ===
node_modules/
.pnpm-store/

# === Test outputs ===
test-results/
playwright-report/
/coverage/
/results/
# Screenshot baselines are committed; only ignore temp files
tests/e2e/__screenshots__/*-retry*

# === Storybook ===
*storybook.log
/storybook-static/

# === Vite / dev caches ===
.vite/
.cache/
.turbo/

# === pnpm / npm pack outputs ===
*.tgz
pnpm-debug.log
npm-debug.log

# === Python / pixi ===
.pixi/
__pycache__/
*.pyc
*.egg-info/
.env

# === Editor / OS noise ===
.DS_Store
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.example.json
*.swp
*.swo

# Generated docs (TypeDoc + Storybook build)
docs-out/
.verify-types
.verify-snippets
scripts/visual-acceptance/.build
scripts/visual-acceptance/dist
test-results.json
