{
  "name": "g3-toolkit",
  "version": "1.0.0-rc",
  "description": "A composable, paradigm-neutral graph visualization toolkit for RDF, LPG, and Holonic architectures.",
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "ARCHITECTURE.md",
    "LICENSE"
  ],
  "keywords": [],
  "author": "",
  "license": "Apache-2.0",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "vite",
    "build": "pnpm run build:packages && tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lint": "eslint src/ packages/core/src/ packages/react/src/ packages/charts/src/ tests/ && prettier --check src/ packages/core/src/ packages/react/src/ packages/charts/src/ tests/",
    "lint:fix": "eslint --fix src/ tests/ && prettier --write src/ tests/",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "build:packages": "tsc -b packages/core packages/react packages/charts --force && pnpm --filter \"./packages/*\" --workspace-concurrency=1 run build",
    "verify:treeshake": "node scripts/verify-treeshake.mjs",
    "verify:smoke": "node scripts/smoke-test.mjs",
    "verify:bundle": "node scripts/check-bundle-size.mjs",
    "verify:stats": "node scripts/workspace-stats.mjs",
    "verify": "pnpm run build:packages && pnpm run verify:treeshake && pnpm run verify:smoke && pnpm run verify:bundle",
    "test:storybook": "vitest run --config vitest.storybook.config.ts"
  },
  "peerDependencies": {
    "@tanstack/react-table": "^8.21.3",
    "cytoscape": ">=3.28.0",
    "echarts": ">=5.0.0",
    "echarts-for-react": "^3.0.6",
    "flexlayout-react": "^0.9.1",
    "fuse.js": "^7.3.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "vis-data": "^8.0.4",
    "vis-timeline": "^8.5.1",
    "zustand": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "echarts": {
      "optional": true
    },
    "cytoscape": {
      "optional": true
    },
    "flexlayout-react": {
      "optional": true
    },
    "vis-data": {
      "optional": true
    },
    "vis-timeline": {
      "optional": true
    },
    "@tanstack/react-table": {
      "optional": true
    },
    "fuse.js": {
      "optional": true
    },
    "echarts-for-react": {
      "optional": true
    }
  },
  "dependencies": {
    "@g3t/core": "workspace:*",
    "@g3t/react": "workspace:*",
    "@g3t/charts": "workspace:*"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@storybook/addon-a11y": "^10.4.1",
    "@storybook/addon-docs": "^10.4.1",
    "@storybook/addon-mcp": "^0.6.0",
    "@storybook/addon-vitest": "^10.4.1",
    "@storybook/react": "^10.4.1",
    "@storybook/react-vite": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/cytoscape": "^3.21.9",
    "@types/d3-force": "^3.0.10",
    "@types/d3-hierarchy": "^3.1.7",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/browser-playwright": "^4.1.7",
    "@vitest/coverage-v8": "^4.1.7",
    "cytoscape-fcose": "^2.2.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-storybook": "^10.4.1",
    "jsdom": "^29.1.1",
    "playwright": "^1.60.0",
    "prettier": "^3.8.3",
    "rollup-plugin-visualizer": "^7.0.1",
    "storybook": "^10.4.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vite": "^8.0.13",
    "vitest": "^4.1.7",
    "@dagrejs/dagre": "^3.0.0",
    "cytoscape": ">=3.28.0",
    "d3-force": "^3.0.0",
    "d3-hierarchy": "^3.1.2",
    "echarts": ">=5.0.0",
    "elkjs": "^0.11.1",
    "expr-eval": "^2.0.2",
    "graphology": "^0.26.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "simple-statistics": "^7.8.9",
    "zustand": ">=4.0.0"
  },
  "sideEffects": [
    "*.css"
  ],
  "packageManager": "pnpm@11.3.0",
  "private": true,
  "engines": {
    "node": ">=22.13"
  }
}
