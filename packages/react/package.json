{
  "name": "@g3t/react",
  "version": "1.0.0-rc.2",
  "description": "React components for graph visualization: canvas, table, tree, map, schema, charts. Pairs with @g3t/core.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./views": {
      "types": "./dist/views/index.d.ts",
      "import": "./dist/views.mjs",
      "require": "./dist/views.cjs"
    },
    "./controls": {
      "types": "./dist/interaction/index.d.ts",
      "import": "./dist/controls.mjs",
      "require": "./dist/controls.cjs"
    },
    "./state": {
      "types": "./dist/state/index.d.ts",
      "import": "./dist/state.mjs",
      "require": "./dist/state.cjs"
    },
    "./theme": {
      "types": "./dist/theme/index.d.ts",
      "import": "./dist/theme.mjs",
      "require": "./dist/theme.cjs"
    },
    "./a11y": {
      "types": "./dist/a11y/index.d.ts",
      "import": "./dist/a11y.mjs",
      "require": "./dist/a11y.cjs"
    },
    "./icons": {
      "types": "./dist/icons/index.d.ts",
      "import": "./dist/icons.mjs",
      "require": "./dist/icons.cjs"
    },
    "./style.css": "./dist/style.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "keywords": [
    "graph",
    "visualization",
    "react",
    "cytoscape",
    "knowledge-graph"
  ],
  "license": "Apache-2.0",
  "author": "g3-toolkit contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/zwelz3/g3-toolkit.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/zwelz3/g3-toolkit/issues"
  },
  "homepage": "https://github.com/zwelz3/g3-toolkit/tree/main/packages/react#readme",
  "scripts": {
    "build": "vite build",
    "test": "pnpm -w exec vitest run packages/react/src",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "clean": "tsc --build --clean && rm -rf dist"
  },
  "dependencies": {
    "@g3t/core": "workspace:*",
    "fuse.js": "^7.0.0",
    "@tanstack/react-table": "^8.0.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "cytoscape": ">=3.28.0",
    "cytoscape-fcose": ">=2.2.0",
    "zustand": ">=4.0.0",
    "echarts": ">=5.0.0",
    "vis-timeline": ">=7.0.0",
    "vis-data": ">=7.0.0"
  },
  "peerDependenciesMeta": {
    "vis-timeline": {
      "optional": true
    },
    "vis-data": {
      "optional": true
    }
  },
  "sideEffects": [
    "*.css"
  ],
  "devDependencies": {
    "vitest": "^4.1.7",
    "@testing-library/react": "^16.3.2",
    "@storybook/react": "^10.4.1",
    "@storybook/react-vite": "^10.4.1"
  }
}
