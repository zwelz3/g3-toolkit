{
  "name": "@g3t/react",
  "version": "1.0.0-rc",
  "description": "React components for graph visualization (canvas, table, tree, map, etc.).",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./style.css": "./dist/style.css"
  },
  "files": ["dist", "README.md"],
  "keywords": ["graph", "visualization", "react", "cytoscape", "knowledge-graph"],
  "license": "Apache-2.0",
  "dependencies": {
    "fuse.js": "^7.0.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "@g3t/core": "^1.0.0-rc",
    "cytoscape": ">=3.28.0",
    "zustand": ">=4.0.0",
    "@tanstack/react-table": ">=8.0.0"
  },
  "peerDependenciesMeta": {
    "vis-timeline": { "optional": true },
    "vis-data": { "optional": true },
    "@tanstack/react-table": { "optional": true }
  }
}
