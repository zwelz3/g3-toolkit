{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "composite": true,
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "types": [
      "node",
      "vite/client"
    ],
    "paths": {
      "@g3t/core": [
        "../core/src/index.ts"
      ]
    },
    "emitDeclarationOnly": true
  },
  "references": [
    {
      "path": "../core"
    }
  ],
  "include": [
    "src"
  ],
  "exclude": [
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.stories.tsx",
    "dist"
  ]
}
