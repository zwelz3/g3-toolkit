{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "composite": true,
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "types": ["node", "vite/client"],
    "paths": {
      "@g3t/core": ["../core/src/index.ts"],
      "@g3t/react": ["../react/src/index.ts"]
    },
    "emitDeclarationOnly": true
  },
  "references": [
    {
      "path": "../core"
    },
    {
      "path": "../react"
    }
  ],
  "include": ["src"],
  "exclude": ["**/*.test.ts", "**/*.test.tsx", "dist"]
}
