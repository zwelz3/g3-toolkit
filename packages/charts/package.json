{
  "name": "@g3t/charts",
  "version": "1.0.0-rc",
  "description": "Linked statistical charts (bar, scatter, line, pie) for g3-toolkit.",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "README.md"],
  "keywords": ["graph", "charts", "echarts", "visualization"],
  "license": "Apache-2.0",
  "peerDependencies": {
    "react": ">=18.0.0",
    "@g3t/core": "^1.0.0-rc",
    "echarts": ">=5.0.0",
    "echarts-for-react": ">=3.0.0"
  }
}
