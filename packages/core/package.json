{
  "name": "@g3t/core",
  "version": "1.0.0-rc.1",
  "description": "Framework-agnostic graph data model, adapters, and algorithms for the g3-toolkit.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./adapters": {
      "import": "./dist/adapters.mjs",
      "require": "./dist/adapters.cjs",
      "types": "./dist/adapter/index.d.ts"
    },
    "./middleware": {
      "import": "./dist/middleware.mjs",
      "require": "./dist/middleware.cjs",
      "types": "./dist/middleware/index.d.ts"
    },
    "./events": {
      "import": "./dist/events.mjs",
      "require": "./dist/events.cjs",
      "types": "./dist/event-bus/index.d.ts"
    },
    "./projection": {
      "import": "./dist/projection.mjs",
      "require": "./dist/projection.cjs",
      "types": "./dist/projection/index.d.ts"
    },
    "./pipeline": {
      "import": "./dist/pipeline.mjs",
      "require": "./dist/pipeline.cjs",
      "types": "./dist/pipeline/index.d.ts"
    },
    "./shacl": {
      "import": "./dist/shacl.mjs",
      "require": "./dist/shacl.cjs",
      "types": "./dist/shacl/index.d.ts"
    },
    "./diff": {
      "import": "./dist/diff.mjs",
      "require": "./dist/diff.cjs",
      "types": "./dist/diff/index.d.ts"
    },
    "./layout": {
      "import": "./dist/layout.mjs",
      "require": "./dist/layout.cjs",
      "types": "./dist/layout/index.d.ts"
    },
    "./algorithms": {
      "import": "./dist/algorithms.mjs",
      "require": "./dist/algorithms.cjs",
      "types": "./dist/algorithm-adapter/index.d.ts"
    },
    "./undo-redo": {
      "import": "./dist/undo-redo.mjs",
      "require": "./dist/undo-redo.cjs",
      "types": "./dist/undo-redo/index.d.ts"
    },
    "./theme": {
      "import": "./dist/theme.mjs",
      "require": "./dist/theme.cjs",
      "types": "./dist/theme/index.d.ts"
    },
    "./path-analysis": {
      "import": "./dist/path-analysis.mjs",
      "require": "./dist/path-analysis.cjs",
      "types": "./dist/path-analysis/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "keywords": [
    "graph",
    "rdf",
    "lpg",
    "sparql",
    "cypher",
    "gremlin",
    "knowledge-graph"
  ],
  "license": "Apache-2.0",
  "author": "g3-toolkit contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/g3-toolkit/g3-toolkit.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/g3-toolkit/g3-toolkit/issues"
  },
  "homepage": "https://github.com/g3-toolkit/g3-toolkit/tree/main/packages/core#readme",
  "scripts": {
    "build": "vite build",
    "test": "pnpm -w exec vitest run packages/core/src",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "clean": "tsc --build --clean && rm -rf dist"
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "d3-force": "^3.0.0",
    "d3-hierarchy": "^3.1.2",
    "elkjs": "^0.11.1",
    "expr-eval": "^2.0.2",
    "graphology": "^0.26.0",
    "simple-statistics": "^7.8.9"
  },
  "peerDependencies": {},
  "sideEffects": false,
  "devDependencies": {
    "vitest": "^4.1.7",
    "@testing-library/react": "^16.3.2"
  }
}
